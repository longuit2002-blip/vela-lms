# Local-only credentials for docker-compose. Copy to `.env` (gitignored) and adjust if needed.
# These are LOCAL DEV ONLY — never reuse in any shared, staging, or production environment.

POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_local_dev
POSTGRES_DB=lms

MINIO_ROOT_USER=lms_minio
MINIO_ROOT_PASSWORD=lms_minio_local_dev

# Host ports for the Compose services. Defaults match conventional ports; override any that
# collide with something already running on your machine (e.g. a local PostgreSQL on 5432).
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Connection string consumed by the API at runtime (also used by the EF design-time factory as a fallback).
# Keep the Port in sync with POSTGRES_HOST_PORT above.
# Runtime app connection — uses the RLS-subject app role (lms_app), provisioned by migrations (U5).
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=lms;Username=lms_app;Password=lms_app_local_dev
# Maintenance connection — BYPASSRLS role used for migrations, seeding, and the pre-auth login lookup.
ConnectionStrings__PostgresMaintenance=Host=localhost;Port=5432;Database=lms;Username=lms;Password=lms_local_dev

# --- Auth (dev) ---
# Leave the JWT private key empty in dev to auto-generate an ephemeral RSA key on startup.
# In shared/staging/prod, supply a PEM private key from a secret store (never commit it).
# Jwt__PrivateKeyPem=

# Seeder default OrgOwner password. REQUIRED in Development (Seed.Enabled=true) and must be >=12 chars.
# This is a one-time default — the seeded owner is forced to change it on first login.
Seed__OwnerPassword=<change-me-min-12-chars>
