# Local-only credentials for docker-compose. Copy to `.env` (gitignored) and adjust if needed.
# These are LOCAL DEV ONLY — never reuse in any shared, staging, or production environment.

POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_local_dev
POSTGRES_DB=lms

MINIO_ROOT_USER=lms_minio
MINIO_ROOT_PASSWORD=lms_minio_local_dev

# Host ports for the Compose services. Defaults match conventional ports; override any that
# collide with something already running on your machine (e.g. a local PostgreSQL on 5432).
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Connection string consumed by the API at runtime (also used by the EF design-time factory as a fallback).
# Keep the Port in sync with POSTGRES_HOST_PORT above.
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=lms;Username=lms;Password=lms_local_dev
