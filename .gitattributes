# Normalize line endings to LF in the repository for all text files.
* text=auto eol=lf

# Keep Visual Studio / MSBuild files CRLF on checkout for tooling friendliness.
*.sln    text eol=crlf
*.csproj text eol=crlf
*.props  text eol=crlf
*.targets text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
